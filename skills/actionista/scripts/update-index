#!/usr/bin/env bash
# update-index — Fetch latest versions for all tracked GitHub Actions
#
# Uses batched GraphQL queries (one API call per ~50 actions) to update
# actions-index.json with current version data and migration info.
#
# Requirements:
#   - gh (authenticated)
#   - yq
#   - jq

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_DIR="$SCRIPT_DIR/.."
TRACKED_ACTIONS="$SKILL_DIR/tracked-actions.yaml"
INDEX_PATH="$SKILL_DIR/actions-index.json"
BATCH_SIZE=20

# ============================================================================
# Helpers
# ============================================================================

check_requirements() {
    local missing=()
    command -v gh &>/dev/null || missing+=("gh")
    command -v yq &>/dev/null || missing+=("yq")
    command -v jq &>/dev/null || missing+=("jq")

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo "error: missing required tools: ${missing[*]}" >&2
        exit 1
    fi

    if ! gh auth status &>/dev/null 2>&1; then
        echo "error: not authenticated with gh. Run: gh auth login" >&2
        exit 1
    fi
}

# Compute input diff between previous and current major version
# Outputs a JSON migration object or "null"
compute_migration() {
    local prev_inputs_json="$1"  # JSON array of input names (previous major)
    local curr_inputs_json="$2"  # JSON array of input names (current major)
    local prev_major="$3"
    local curr_major="$4"

    if [[ "$prev_inputs_json" == "null" || "$curr_inputs_json" == "null" ]]; then
        echo "null"
        return
    fi

    local migration
    migration=$(jq -n \
        --argjson prev "$prev_inputs_json" \
        --argjson curr "$curr_inputs_json" \
        --arg from "$prev_major" \
        --arg to "$curr_major" \
        '{
            key: ($from + "→" + $to),
            value: {
                inputChanges: {
                    added: ($curr - $prev),
                    removed: ($prev - $curr)
                }
            }
        } | if (.value.inputChanges.added | length) == 0 and (.value.inputChanges.removed | length) == 0
            then null
            else . end')

    echo "$migration"
}

# ============================================================================
# Main
# ============================================================================

main() {
    check_requirements

    echo "Actionista Index Updater"
    echo ""

    # Load existing index for fallback and migration preservation
    local existing='{}'
    if [[ -f "$INDEX_PATH" ]]; then
        existing=$(jq '.actions // {}' "$INDEX_PATH")
    fi

    # Load and deduplicate tracked actions
    local actions=()
    local categories=()
    while IFS=$'\t' read -r action category; do
        actions+=("$action")
        categories+=("$category")
    done < <(
        yq -o=json '.' "$TRACKED_ACTIONS" \
            | jq -r '.categories | to_entries[] | .key as $cat | .value.actions[] | [., $cat] | @tsv' \
            | sort -t$'\t' -k1,1 -u
    )

    local total=${#actions[@]}
    echo "Tracked: ${total} unique actions"

    # First pass: fetch current version data
    local batch_count=$(( (total + BATCH_SIZE - 1) / BATCH_SIZE ))
    echo "Fetching in ${batch_count} GraphQL batch(es)..."
    echo ""

    local all_entries='{}'
    local batch_failures=0
    # Track actions needing migration diff: "action major_num" pairs
    local migration_actions=()
    local migration_majors=()

    for (( batch=0; batch < total; batch += BATCH_SIZE )); do
        local batch_num=$(( batch / BATCH_SIZE + 1 ))
        local end=$(( batch + BATCH_SIZE ))
        [[ $end -gt $total ]] && end=$total
        local count=$(( end - batch ))

        echo "  Batch ${batch_num}/${batch_count} (${count} actions)..."

        # Build GraphQL query inline
        local query='query {'
        for (( i=batch; i < end; i++ )); do
            local owner repo
            IFS='/' read -r owner repo _ <<< "${actions[$i]}"
            query+="
  repo${i}: repository(owner: \"$owner\", name: \"$repo\") {
    nameWithOwner
    description
    latestRelease { tagName tag { target { ... on Commit { sha: oid } ... on Tag { tagTarget: target { ... on Commit { sha: oid } } } } } }
    refs(refPrefix: \"refs/tags/\", first: 1, orderBy: {field: TAG_COMMIT_DATE, direction: DESC}) {
      nodes { name target { ... on Commit { sha: oid } ... on Tag { tagTarget: target { ... on Commit { sha: oid } } } } }
    }
    actionYml: object(expression: \"HEAD:action.yml\") { ... on Blob { text } }
    actionYaml: object(expression: \"HEAD:action.yaml\") { ... on Blob { text } }
    releases(first: 10, orderBy: {field: CREATED_AT, direction: DESC}) {
      nodes { tagName isPrerelease tag { target { ... on Commit { sha: oid } ... on Tag { tagTarget: target { ... on Commit { sha: oid } } } } } }
    }
  }"
        done
        query+=$'\n}'

        local response
        response=$(gh api graphql -f query="$query" 2>/dev/null) || true

        if [[ -z "$response" ]] || ! echo "$response" | jq -e '.data' &>/dev/null; then
            batch_failures=$((batch_failures + 1))
            echo "    warning: batch ${batch_num} failed entirely, using existing data"
            for (( i=batch; i < end; i++ )); do
                local fb
                fb=$(echo "$existing" | jq --arg a "${actions[$i]}" 'if .[$a] then {($a): .[$a]} else empty end')
                [[ -n "$fb" ]] && all_entries=$(echo "$all_entries" "$fb" | jq -s 'add')
            done
            continue
        fi

        for (( i=batch; i < end; i++ )); do
            local action="${actions[$i]}"
            local category="${categories[$i]}"
            local alias="repo${i}"

            local repo_data
            repo_data=$(echo "$response" | jq ".data.${alias} // empty")
            if [[ -z "$repo_data" || "$repo_data" == "null" ]]; then
                local fb
                fb=$(echo "$existing" | jq --arg a "$action" 'if .[$a] then {($a): .[$a]} else empty end')
                [[ -n "$fb" ]] && all_entries=$(echo "$all_entries" "$fb" | jq -s 'add')
                echo "    warning: ${action} — not found, kept existing"
                continue
            fi

            local tag_data tag_name sha
            tag_data=$(echo "$repo_data" | jq '
                def release_sha: (.tag.target.sha // .tag.target.tagTarget.sha // null);
                def ref_sha: (.target.sha // .target.tagTarget.sha // null);
                def best_release:
                    [.[] | select(.isPrerelease == false and (.tagName | test("^v\\d")))] |
                    if length == 0 then null else
                        (map(.tagName | ltrimstr("v") | split(".")[0] | tonumber) | max) as $max |
                        ([.[] | select(.tagName | test("^v" + ($max | tostring) + "\\.\\d"))] | .[0]) //
                        ([.[] | select(.tagName | startswith("v" + ($max | tostring)))] | .[0])
                    end;
                (.releases.nodes // [] | best_release | select(.) | {tag: .tagName, sha: release_sha}) //
                (.latestRelease | select(.tagName) | {tag: .tagName, sha: release_sha}) //
                (.refs.nodes[0] | select(.name) | {tag: .name, sha: ref_sha}) //
                {tag: null, sha: null}')

            tag_name=$(echo "$tag_data" | jq -r '.tag // empty')
            sha=$(echo "$tag_data" | jq -r '.sha // empty')

            if [[ -z "$tag_name" ]]; then
                echo "    warning: ${action} — no tags found, skipped"
                continue
            fi

            local major_num major_version
            major_num=$(echo "$tag_name" | sed -n 's/^v\{0,1\}\([0-9]*\).*/\1/p')
            major_version="v${major_num}"

            local description
            description=$(echo "$repo_data" | jq -r '.description // "" | .[0:100]')

            local deprecated="[]"
            if [[ -n "$major_num" && "$major_num" -gt 2 ]]; then
                deprecated=$(seq 1 $((major_num - 2)) | jq -R '"v\(.)"' | jq -s .)
            fi

            local action_text inputs="null"
            action_text=$(echo "$repo_data" | jq -r '.actionYml.text // .actionYaml.text // empty')
            if [[ -n "$action_text" ]]; then
                inputs=$(echo "$action_text" | yq -o=json '.inputs | keys' 2>/dev/null || echo "null")
            fi

            local entry_migrations=""

            # Queue for migration diff if major > 1 AND version actually changed
            if [[ -n "$major_num" && "$major_num" -gt 1 ]]; then
                local prev_full
                prev_full=$(echo "$existing" | jq -r --arg a "$action" '.[$a].latestFull // empty')
                if [[ "$prev_full" == "$tag_name" ]]; then
                    # Version unchanged — carry forward existing migrations
                    local prev_mig
                    prev_mig=$(echo "$existing" | jq -c --arg a "$action" '.[$a].migrations // empty')
                    if [[ -n "$prev_mig" && "$prev_mig" != "null" ]]; then
                        entry_migrations="$prev_mig"
                    fi
                else
                    migration_actions+=("$action")
                    migration_majors+=("$major_num")
                fi
            fi

            local entry
            entry=$(jq -n \
                --arg action "$action" \
                --arg latest "$major_version" \
                --arg latestFull "$tag_name" \
                --arg sha "$sha" \
                --arg description "$description" \
                --arg category "$category" \
                --argjson deprecated "$deprecated" \
                --argjson inputs "$inputs" \
                '{
                    ($action): (
                        {latest: $latest, latestFull: $latestFull, description: $description, category: $category}
                        + (if $sha != "" then {sha: $sha} else {} end)
                        + (if $deprecated | length > 0 then {deprecated: $deprecated} else {} end)
                        + (if $inputs != null and ($inputs | length) > 0 then {inputs: $inputs} else {} end)
                    )
                }')

            # Attach carried-forward migrations (from unchanged actions)
            if [[ -n "$entry_migrations" ]]; then
                entry=$(echo "$entry" | jq --arg a "$action" --argjson m "$entry_migrations" '.[$a].migrations = $m')
            fi

            all_entries=$(echo "$all_entries" "$entry" | jq -s 'add')
        done
    done

    # Second pass: fetch previous major action.yml for migration diffs
    local mig_total=${#migration_actions[@]}
    local carried_forward
    carried_forward=$(echo "$all_entries" | jq '[to_entries[] | select(.value.migrations)] | length')
    if [[ $mig_total -gt 0 ]]; then
        local mig_batch_count=$(( (mig_total + BATCH_SIZE - 1) / BATCH_SIZE ))
        echo ""
        echo "Computing migrations for ${mig_total} changed actions (${mig_batch_count} batch(es)), ${carried_forward} carried forward..."

        for (( batch=0; batch < mig_total; batch += BATCH_SIZE )); do
            local batch_num=$(( batch / BATCH_SIZE + 1 ))
            local end=$(( batch + BATCH_SIZE ))
            [[ $end -gt $mig_total ]] && end=$mig_total

            echo "  Migration batch ${batch_num}/${mig_batch_count}..."

            # Build query for previous major action.yml
            local query='query {'
            for (( i=batch; i < end; i++ )); do
                local owner repo
                IFS='/' read -r owner repo _ <<< "${migration_actions[$i]}"
                local prev_major="v$(( migration_majors[i] - 1 ))"
                query+="
  mig${i}: repository(owner: \"$owner\", name: \"$repo\") {
    prevYml: object(expression: \"${prev_major}:action.yml\") { ... on Blob { text } }
    prevYaml: object(expression: \"${prev_major}:action.yaml\") { ... on Blob { text } }
  }"
            done
            query+=$'\n}'

            local response
            response=$(gh api graphql -f query="$query" 2>/dev/null) || true

            if [[ -z "$response" ]] || ! echo "$response" | jq -e '.data' &>/dev/null; then
                echo "    warning: migration batch ${batch_num} failed"
                continue
            fi

            for (( i=batch; i < end; i++ )); do
                local action="${migration_actions[$i]}"
                local major_num="${migration_majors[$i]}"
                local prev_major="v$(( major_num - 1 ))"
                local curr_major="v${major_num}"
                local alias="mig${i}"

                local mig_data
                mig_data=$(echo "$response" | jq ".data.${alias} // empty")
                if [[ -z "$mig_data" || "$mig_data" == "null" ]]; then
                    continue
                fi

                # Parse previous version inputs
                local prev_text prev_inputs="null"
                prev_text=$(echo "$mig_data" | jq -r '.prevYml.text // .prevYaml.text // empty')
                if [[ -n "$prev_text" ]]; then
                    prev_inputs=$(echo "$prev_text" | yq -o=json '.inputs | keys' 2>/dev/null || echo "null")
                fi

                # Get current inputs from the entry we already built
                local curr_inputs
                curr_inputs=$(echo "$all_entries" | jq --arg a "$action" '.[$a].inputs // null')

                # Compute migration
                local migration
                migration=$(compute_migration "$prev_inputs" "$curr_inputs" "$prev_major" "$curr_major")

                if [[ "$migration" != "null" && -n "$migration" ]]; then
                    local mig_key mig_value
                    mig_key=$(echo "$migration" | jq -r '.key')
                    mig_value=$(echo "$migration" | jq -c '.value')

                    # Preserve any existing Claude-written summary/notes for this migration
                    local existing_mig
                    existing_mig=$(echo "$existing" | jq -c --arg a "$action" --arg k "$mig_key" '.[$a].migrations[$k] // empty')

                    if [[ -n "$existing_mig" && "$existing_mig" != "null" ]]; then
                        # Merge: keep existing summary/notes, update inputChanges
                        mig_value=$(echo "$existing_mig" "$mig_value" | jq -s '.[0] * .[1]')
                    fi

                    # Add migration to the action entry
                    all_entries=$(echo "$all_entries" | jq \
                        --arg a "$action" \
                        --arg k "$mig_key" \
                        --argjson v "$mig_value" \
                        '.[$a].migrations = ((.[$a].migrations // {}) + {($k): $v})')
                fi
            done
        done
    else
        if (( carried_forward > 0 )); then
            echo ""
            echo "No version changes — ${carried_forward} migrations carried forward"
        fi
    fi

    # Build final index — with safety checks
    local action_count existing_count now
    action_count=$(echo "$all_entries" | jq 'length')
    existing_count=$(echo "$existing" | jq 'length')
    now=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    if [[ "$action_count" -eq 0 ]]; then
        echo "" >&2
        echo "error: ended up with 0 actions — all batches likely failed (${batch_failures}/${batch_count} failed)" >&2
        echo "Refusing to overwrite index. Existing file preserved." >&2
        exit 1
    fi

    if [[ "$existing_count" -gt 0 ]]; then
        local loss_pct=$(( (existing_count - action_count) * 100 / existing_count ))
        if [[ "$loss_pct" -gt 10 ]]; then
            echo "" >&2
            echo "error: would drop from ${existing_count} to ${action_count} actions (${loss_pct}% loss)" >&2
            echo "${batch_failures}/${batch_count} batch(es) failed. Refusing to overwrite index." >&2
            exit 1
        fi
    fi

    local tmp_index="${INDEX_PATH}.tmp"

    if ! echo "$all_entries" | jq \
        --arg generated "$now" \
        --argjson count "$action_count" \
        '{
            _metadata: {
                generated: $generated,
                generator: "actionista",
                actionCount: $count,
                note: "This index is updated daily by .github/workflows/update-index.yml"
            },
            actions: .
        }' > "$tmp_index"; then
        echo "error: jq failed to build index — existing file preserved" >&2
        exit 1
    fi

    mv "$tmp_index" "$INDEX_PATH"

    echo ""
    echo "Updated index: ${action_count} actions (${batch_failures}/${batch_count} batch failures)"

    # Summary: compare against existing
    local added=0 updated=0 unchanged=0 migrations=0
    while IFS=$'\t' read -r action new_full; do
        local old_full
        old_full=$(echo "$existing" | jq -r --arg a "$action" '.[$a].latestFull // empty')

        if [[ -z "$old_full" ]]; then
            added=$((added + 1))
        elif [[ "$new_full" != "$old_full" ]]; then
            updated=$((updated + 1))
            echo "  ${action}: ${old_full} -> ${new_full}"
        else
            unchanged=$((unchanged + 1))
        fi
    done < <(echo "$all_entries" | jq -r 'to_entries[] | [.key, .value.latestFull] | @tsv')

    migrations=$(echo "$all_entries" | jq '[to_entries[] | select(.value.migrations)] | length')

    echo ""
    echo "Summary: ${added} added, ${updated} updated, ${unchanged} unchanged, ${migrations} with migrations"
    if [[ "$batch_failures" -gt 0 ]]; then
        echo "Warning: ${batch_failures}/${batch_count} batch(es) failed — some actions may be stale"
    fi
}

main "$@"
